{
  "name": "salmon-loop",
  "version": "0.2.0",
  "description": "A minimal viable execution loop for automated code patching",
  "type": "module",
  "bin": {
    "salmon-loop": "dist/cli/index.js"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm && node scripts/check-versions.js",
    "check-deps": "node scripts/check-deps.js",
    "build": "tsc && node scripts/copy-assets.js",
    "dev": "tsx src/cli/index.ts",
    "test": "pnpm test:unit",
    "t": "vitest tests/unit/",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:full": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:full",
    "test:watch": "vitest",
    "test:watch:unit": "vitest tests/unit/",
    "test:watch:integration": "vitest tests/integration/",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "test:watch:perf": "vitest --config vitest.perf.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run --reporter=default --reporter=json --outputFile=test-report.json",
    "test:ci": "eslint . && vitest run --reporter=verbose --coverage",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "code",
    "automation",
    "patch",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/react": "^16.3.2",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^20.0.0",
    "@types/progress": "^2.0.7",
    "@types/react": "^19.2.10",
    "@types/sinon": "^21.0.0",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^27.4.0",
    "mock-fs": "^5.5.0",
    "prettier": "^3.4.2",
    "simple-git": "^3.30.0",
    "sinon": "^21.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.53.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.23",
    "@ai-sdk/openai-compatible": "^2.0.24",
    "@inquirer/prompts": "^8.2.0",
    "ai": "^6.0.62",
    "chalk": "^5.4.1",
    "commander": "^11.1.0",
    "dotenv": "^17.2.3",
    "execa": "^9.6.1",
    "handlebars": "^4.7.8",
    "ink": "^6.6.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^6.16.0",
    "progress": "^2.0.3",
    "react": "^19.2.4",
    "tree-sitter-javascript": "^0.25.0",
    "web-tree-sitter": "0.26.3",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  }
}
