#!/usr/bin/env bash
set -euo pipefail

if [[ -x "${HOME}/.bun/bin/bun" ]]; then
  export PATH="${HOME}/.bun/bin:${PATH}"
fi

if ! command -v bun >/dev/null 2>&1; then
  echo "pre-commit: bun is required but not found in PATH" >&2
  exit 1
fi

bun run check:target-runtime-boundary:staged
bun run check:bun-purity:staged
bun run check:unit-boundary:staged
bun run check:bun-manifest
